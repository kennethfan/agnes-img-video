# API Key 文件路径（必需）
# Key 存储在单独文件，不在 .env 中直接写 key
API_KEY_PATH=~/.agnes/api-key

# API 地址（可选，有默认值）
BASE_URL=https://apihub.agnes-ai.com/v1

# 模型覆盖（可选，有默认值）
IMAGE_MODEL=agnes-image-2.1-flash
VIDEO_MODEL=agnes-video-v2.0
CHAT_MODEL=agnes-2.0-flash

# GitHub 文件存储（可选）
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BRANCH=master

# 数据库（可选，有默认值）
DB_DRIVER=sqlite
DB_DSN=history.db

# 服务器端口（可选，默认 8080）
PORT=8080
